# ────────────────────────────────────────────────────────────────
# sendoc — environment variables
# Copy this file to ".env.local" and fill in your real values.
# Do NOT commit .env.local — it's already in .gitignore.
# ────────────────────────────────────────────────────────────────

# ─── Firebase (CLIENT) ─────────────────────────────────────────
# Get these from Firebase Console → Project Settings → "Your apps" → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase (SERVER) ─────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service accounts
# → "Generate new private key" → opens a JSON file. Copy values from there.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# IMPORTANT: paste the private key WITH the \n as literal text and wrap in double quotes.
# Example: FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Anthropic (Claude) ────────────────────────────────────────
# Get from https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Real-time collab ──────────────────────────────────────────
# WebSocket URL for the Hocuspocus server (in /collab/). When set,
# /edit/[editToken] connects to this for multi-user editing with
# live cursors. When unset, the editor runs in single-user mode
# (in-memory Yjs only — still functional).
#
# Local dev:  ws://localhost:1234
# Production: wss://sendoc-collab.fly.dev (or your Fly app URL)
NEXT_PUBLIC_COLLAB_URL=

# ─── Secret pepper for API keys + edit tokens ──────────────────
# Used to HMAC-hash credentials before storing in Firestore. If the DB
# leaks, an attacker still can't validate keys offline without this.
# Generate with: openssl rand -hex 32
# IMPORTANT: rotating this value invalidates every existing API key and
# edit token. Only rotate on a known compromise.
API_KEY_PEPPER=
